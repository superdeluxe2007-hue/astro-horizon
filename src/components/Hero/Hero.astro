---
/**
 * * Hero with background image
 * You'll want a mobile image, and a desktop image for this.
 */

import Button from "@components/Button/Button.astro";
import heroImage from "@images/enlee-venue-night.jpg";
import heroImageMobile from "@images/enlee-venue-night.jpg";
import { Image } from "astro:assets";
---

<section id="hero" class="relative z-10 flex min-h-[100lvh] w-full">
	<!-- background image -->
	<div class="absolute -z-10 h-full min-h-full w-full overflow-hidden">
		<div class="absolute inset-0 bg-black/10"></div>

		<Image
			src={heroImage}
			class="hidden h-auto min-h-full w-full object-cover object-[center_70%] sm:block"
			alt="Enlee ガーデンレストラン外観"
			aria-hidden="true"
			loading="eager"
			height={1400}
		/>
		<Image
			src={heroImageMobile}
			class="h-auto min-h-full w-full object-cover sm:hidden"
			alt="Enlee ガーデンレストラン外観"
			aria-hidden="true"
			loading="eager"
			width={1200}
		/>
	</div>

	<!-- hero items -->
	<div class="site-container relative w-full gap-10 py-44 text-center md:py-52 md:text-left">
		<!-- Hero text -->
		<div class="text-base-50 my-auto mr-auto max-w-[800px] flex-col">
			<p
				class="text-sm tracking-[0.3em] text-pretty uppercase drop-shadow-[0_1px_1px_rgba(0,0,0,0.3)] md:text-base"
			>
				福山市 中央公園内 ガーデンレストラン
			</p>
			<h1
				class="font-heading-1 mt-4 text-5xl leading-snug font-semibold text-pretty drop-shadow-[0_2px_2px_rgba(0,0,0,0.4)] md:mt-6 md:text-8xl"
			>
				Enlee
			</h1>
			<p
				class="mt-8 text-lg tracking-wide text-pretty drop-shadow-[0_1px_1px_rgba(0,0,0,0.2)] md:mt-10 md:max-w-[550px] md:text-2xl"
			>
				緑に包まれるランチの時間も、灯りの下で過ごす夜のカフェタイムも。福山・中央公園の庭で、少しだけ特別な一日を。
			</p>
			<div class="mt-12 flex flex-wrap justify-center gap-4 md:justify-start">
				<Button
					variant="ghost"
					arrow="right"
					href="/#concept"
					class="pl-0 text-xl text-white drop-shadow-[0_1px_1px_rgba(0,0,0,0.2)] md:text-3xl"
				>
					エンリーのこと
				</Button>
			</div>
		</div>
	</div>
</section>
