---
/**
 * * Contact section for the website
 */

import { Image } from "astro:assets";

interface Props {
	class?: string;
}

const { class: className } = Astro.props as Props;

import venueImage from "@assets/images/enlee-venue-night.jpg";
---

<section
	id="contact"
	class="mx-auto max-w-md scroll-mt-10 px-4 py-20 md:max-w-6xl md:py-32"
	class:list={[className]}
>
	<h2 class="h2 md:px-12 lg:text-6xl">ご予約・お問い合わせ</h2>
	<div class="mt-4 grid gap-y-14 md:mt-0 md:grid-cols-2">
		<div class="border-primary-300 pt-10 md:border-r md:pr-20 md:pl-12">
			<p class="description text-lg">
				団体様の宴会・BBQ・お弁当やオードブルのご注文は、お電話または公式LINEにて承ります。ご注文は2営業日前までにお願いいたします。ご希望に添えない場合もございますので、お早めにご相談ください。
			</p>
			<div class="mx-auto mt-10 aspect-square overflow-hidden">
				<Image
					src={venueImage}
					alt="Enlee外観"
					width={450}
					densities={[1.5, 2]}
					class="h-full w-full object-cover"
				/>
			</div>
		</div>
		<div class="md:pr-12 md:pl-20">
			<dl class="flex flex-col gap-8 pt-10 text-lg lg:text-xl">
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">TEL</dt>
					<dd class="mt-2">
						<a href="tel:0849997006" class="hover:text-primary-500 transition">084-999-7006</a>
					</dd>
				</div>
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">公式LINE</dt>
					<dd class="mt-2">予約・お問い合わせはLINEからもお気軽にどうぞ</dd>
				</div>
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">住所</dt>
					<dd class="mt-2">福山市霞町1-10-2（中央公園内）</dd>
				</div>
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">営業時間</dt>
					<dd class="mt-2">11:00–21:00（L.O 20:00）／定休日：火曜日</dd>
				</div>
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">アクセス</dt>
					<dd class="mt-2">中央図書館・ローズコムに隣接。会議のあとの懇親会にも便利です。</dd>
				</div>
			</dl>
		</div>
	</div>
</section>
