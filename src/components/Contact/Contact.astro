---
/**
 * * Contact section for the website
 */

import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

interface Props {
	class?: string;
}

const { class: className } = Astro.props as Props;

import venueImage from "@assets/images/enlee-venue-night.jpg";
---

<section
	id="contact"
	class="mx-auto max-w-md scroll-mt-10 px-4 py-20 md:max-w-6xl md:py-32"
	class:list={[className]}
>
	<h2 class="h2 md:px-12 lg:text-6xl">ご予約・お問い合わせ</h2>
	<div class="mt-4 grid gap-y-14 md:mt-0 md:grid-cols-2">
		<div class="border-primary-300 pt-10 md:border-r md:pr-20 md:pl-12">
			<p class="description text-lg">
				ランチのご予約から、貸切パーティーやお弁当のご相談まで。お電話または公式LINEからお気軽にお問い合わせください。
			</p>
			<div class="mx-auto mt-10 aspect-square overflow-hidden">
				<Image
					src={venueImage}
					alt="Enlee外観"
					width={450}
					densities={[1.5, 2]}
					class="h-full w-full object-cover"
				/>
			</div>
		</div>
		<div class="md:pr-12 md:pl-20">
			<div class="flex flex-col gap-4 pt-10 sm:flex-row">
				<a
					href="https://lin.ee/ngJUcCC"
					target="_blank"
					rel="noopener noreferrer"
					class="border-primary-300 hover:bg-primary-50 flex items-center justify-center gap-3 border px-6 py-4 text-lg font-medium transition"
				>
					<Icon name="socials/line" class="size-6 shrink-0" />
					<span class="underline underline-offset-4">LINEでお問い合わせ</span>
				</a>
				<a
					href="https://www.instagram.com/enlee_fukuyama/"
					target="_blank"
					rel="noopener noreferrer"
					class="border-primary-300 hover:bg-primary-50 flex items-center justify-center gap-3 border px-6 py-4 text-lg font-medium transition"
				>
					<Icon name="socials/basil-instagram-solid" class="size-6 shrink-0" />
					<span class="underline underline-offset-4">Instagramをフォロー</span>
				</a>
			</div>
			<dl class="flex flex-col gap-8 pt-10 text-lg lg:text-xl">
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">TEL</dt>
					<dd class="mt-2">
						<a href="tel:0849997006" class="hover:text-primary-500 transition">084-999-7006</a>
					</dd>
				</div>
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">住所</dt>
					<dd class="mt-2">福山市霞町1-10-2（中央公園内）</dd>
				</div>
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">営業時間</dt>
					<dd class="mt-2">11:00–21:00（L.O 20:00）／定休日：火曜日</dd>
				</div>
				<div>
					<dt class="font-heading-1 tracking-wide uppercase">アクセス</dt>
					<dd class="mt-2">専用駐車場はございません。近隣のコインパーキングをご利用ください。</dd>
				</div>
			</dl>
		</div>
	</div>
</section>
